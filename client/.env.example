# Base URL of the backend, including the /api suffix.
#
# Read at BUILD time by Vite, not at runtime — rebuild after changing it.
# Leave unset for local work: the client falls back to http://localhost:8000/api,
# which is what `docker compose up` serves.
#
# Deployed (Cloudflare Worker):
# VITE_API_BASE=https://arch-sketch-api.<your-subdomain>.workers.dev/api
